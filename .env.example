# Database
DATABASE_URL=file:./db/custom.db

# Auth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=change-this-in-production
NEXTAUTH_URL=http://localhost:3000

# M-Pesa Daraja — register at https://developer.safaricom.co.ke
# Leave unset to run checkout in demo mode (orders still save to DB)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback

# Cloudinary — register at https://cloudinary.com
# Leave unset to use placeholder images in admin upload
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# To create an admin user:
# bun scripts/seed-admin.ts
# Default: admin@kicksmtaani.co.ke / admin12345
