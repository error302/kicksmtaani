# ─────────────────────────────────────────────────────────
# KicksMtaani — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Database (REQUIRED)
# Use PostgreSQL for production (Prisma Postgres, Neon, Supabase, Vercel Postgres)
# For local dev: run a local Postgres or use Docker:
#   docker run --name kicksmtaani-db -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=kicksmtaani -p 5432:5432 -d postgres:16
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Auth (REQUIRED — generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=change-this-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# ─── OPTIONAL: M-Pesa Daraja ───
# Register at https://developer.safaricom.co.ke
# Leave unset to run checkout in demo mode (orders still save to DB)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback

# ─── OPTIONAL: Cloudinary (image uploads) ───
# Register at https://cloudinary.com
# Leave unset to use placeholder images in admin upload
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── TO SET UP THE DATABASE ───
# After setting DATABASE_URL, run:
#   bash scripts/deploy-db.sh
# This creates all tables, seeds 102 products + 25 brands,
# and creates the admin user (admin@kicksmtaani.co.ke / admin12345)
