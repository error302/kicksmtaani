// KicksMtaani — Premium Sneaker Marketplace Schema
// SQLite-compatible: arrays are stored as JSON strings

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  phone        String?
  passwordHash String
  fullName     String?
  role         String    @default("CUSTOMER") // CUSTOMER | ADMIN
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orders    Order[]
  addresses Address[]
}

model Address {
  id        String  @id @default(cuid())
  userId    String
  label     String // Home, Work, etc.
  fullName  String
  phone     String
  address   String
  city      String
  notes     String?
  isDefault Boolean @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  logoUrl     String?
  country     String?
  description String?
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  products    Product[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  brandId     String
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  category    String // MEN | WOMEN | KIDS | UNISEX
  description String?
  basePrice   Float
  compareAt   Float?
  images      String // JSON array of image URLs
  sizes       String // JSON array of strings
  colors      String // JSON array of {name,hex}
  rating      Float    @default(5)
  reviewCount Int      @default(0)
  inStock     Boolean  @default(true)
  stockQty    Int      @default(0)
  isFeatured  Boolean  @default(false)
  isNew       Boolean  @default(false)
  tags        String? // JSON array of strings
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([brandId])
  @@index([category])
  @@index([isFeatured])
  @@index([isNew])
}

model Order {
  id            String   @id @default(cuid())
  orderNumber   String   @unique
  userId        String?
  email         String
  phone         String
  fullName      String
  address       String
  city          String
  notes         String?
  items         String // JSON array of items
  subtotal      Float
  shipping      Float
  total         Float
  status        String   @default("PENDING") // PENDING | CONFIRMED | PROCESSING | SHIPPED | DELIVERED | CANCELLED | REFUNDED
  paymentMethod String   @default("MPESA") // MPESA | CARD | CASH
  paymentStatus String   @default("PENDING") // PENDING | SUCCESS | FAILED | REFUNDED
  mpesaRef      String? // M-Pesa confirmation code
  courier       String? // dispatch info
  trackingNo    String? // tracking number
  dispatchedAt  DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}
